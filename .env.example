# =============================================================================
# Commission Tracker — environment variables
# Copy to .env for local dev. On Vercel, set these in Project → Settings →
# Environment Variables (do NOT commit real values).
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# DATABASE_URL  = pooled connection (used by the app at runtime, serverless-safe)
# DIRECT_URL    = direct / non-pooled connection (used only for migrations)
#
# Vercel Postgres / Neon: after adding the integration, Vercel injects the
# connection strings automatically. Map them like this:
#   DATABASE_URL  -> the POOLED url  (Neon: ...-pooler... / "DATABASE_URL")
#   DIRECT_URL    -> the UNPOOLED url (Neon: "DATABASE_URL_UNPOOLED")
# If your provider has no separate pooled URL, set both to the same value.
DATABASE_URL="postgresql://user:password@host:5432/commission_tracker?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/commission_tracker?sslmode=require"

# --- Security secrets (generate with: openssl rand -base64 32) ---------------
# Signs the HTTP-only session cookie. Must be >= 32 characters.
SESSION_SECRET="replace-with-32-byte-random-secret"
# Encrypts private placement/adjustment notes before they touch the database.
# Must decode to exactly 32 bytes (base64 of 32 random bytes does).
APP_ENCRYPTION_KEY="replace-with-32-byte-base64-key"

# --- App ---------------------------------------------------------------------
# Public HTTPS URL of the deployment (used for the settings checklist + links).
BASE_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="Commission Tracker"

# --- Initial admin (read once by `npm run db:seed`) --------------------------
# Create the first admin login. Change the password right after first sign-in.
ADMIN_EMAIL="adrianr@eggersesearch.com"
ADMIN_NAME="Adrian Rider"
ADMIN_PASSWORD="change-this-to-a-long-random-password"

# Set to "true" only if you want a sanitized sample recruiter + plan + two paid
# placements created by the seed (handy for a first look). Leave blank in prod.
ALLOW_SAMPLE_DATA=""

# --- Loxo webhook (optional) -------------------------------------------------
# Shared secret used to verify the HMAC-SHA256 signature on incoming Loxo
# placement webhooks. Leave blank to disable the webhook (rejects all calls).
LOXO_WEBHOOK_SECRET=""
# Fallback recruiter id used when a Loxo payload can't identify a recruiter.
DEFAULT_LOXO_RECRUITER_ID=""
